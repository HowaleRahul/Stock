# =====================================================================
# PERSONAL AI-ASSISTED TRADING SYSTEM — ENVIRONMENT CONFIGURATION
# =====================================================================
# Copy this file to .env and insert your real credentials & settings.
# Never commit `.env` to Git!

# ---------------------------------------------------------------------
# 1. APPLICATION ENVIRONMENT
# ---------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
API_PORT=8000
API_HOST=127.0.0.1

# ---------------------------------------------------------------------
# 2. DATABASE CONFIGURATION (PostgreSQL + TimescaleDB)
# ---------------------------------------------------------------------
# Default local docker-compose connection string (uses asyncpg driver):
DATABASE_URL=postgresql+asyncpg://postgres:trading_secret_pwd@127.0.0.1:5432/trading_db

# ---------------------------------------------------------------------
# 3. TARGET FOCUS SYMBOLS (3-5 Symbols/Indices for Phase 0 & Phase 1)
# ---------------------------------------------------------------------
# JSON list or comma-separated symbols to track & process:
# Indian Market Defaults (F&O and Equity):
TARGET_SYMBOLS=["NIFTY", "BANKNIFTY", "RELIANCE.NS", "HDFCBANK.NS", "TCS.NS"]

# US Market Alternatives (Uncomment if focusing on US):
# TARGET_SYMBOLS=["SPY", "QQQ", "AAPL", "NVDA", "MSFT"]

# ---------------------------------------------------------------------
# 4. BROKER & DATA PROVIDER API SECRETS (Phase 1+ placeholders)
# ---------------------------------------------------------------------
# Zerodha Kite (NSE India)
KITE_API_KEY=your_kite_api_key_here
KITE_API_SECRET=your_kite_api_secret_here

# AngelOne SmartAPI / Upstox (Alternative NSE Brokers)
ANGEL_API_KEY=your_angel_api_key_here
UPSTOX_API_KEY=your_upstox_api_key_here

# US Data Providers (Polygon, AlphaVantage, Yahoo Finance)
POLYGON_API_KEY=your_polygon_api_key_here
ALPHAVANTAGE_API_KEY=your_alphavantage_api_key_here
